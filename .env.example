# Supabase 프로젝트 만든 후 여기에 키 넣기
# Vercel 대시보드에서도 동일하게 등록 필요

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 사이트 URL (OAuth 콜백/SEO용)
NEXT_PUBLIC_SITE_URL=https://we.hannipmoney.com
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ETF 시세: 공공데이터포털 금융위원회_증권상품시세정보 서비스키
DATA_GO_KR_SERVICE_KEY=your-public-data-service-key

# 자동번역 (영어권 브라우저에서 버튼 없이 자동 표시)
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini

# Vercel Cron RSS 수집 보호용
CRON_SECRET=replace-with-random-secret
